# ── Required ──────────────────────────────────────────────────────────────────

# Admin login password for the portal
ADMIN_PASSWORD=Duke2024!

# Secret used to sign JWTs — use a long random string in production
JWT_SECRET=change-this-to-a-random-string

# ── Persistent storage (Railway volume) ───────────────────────────────────────
# Path where SQLite DB and uploaded photos are stored.
# In Railway: set this to the mount path of your persistent volume (e.g. /data)
# Leave blank for local development (defaults to server/data)
DATA_DIR=

# ── Azure AD SSO (optional — for ambassador login via Duke SSO) ───────────────
AZURE_CLIENT_ID=your-client-id-from-duke-oit
AZURE_CLIENT_SECRET=your-client-secret-from-duke-oit
AZURE_TENANT_ID=your-duke-tenant-id-from-duke-oit

# In production, must match the redirect URI registered in Azure:
#   https://your-app.up.railway.app/api/auth/callback
AZURE_REDIRECT_URI=http://localhost:3001/api/auth/callback

# Production URL of this app (used for SSO redirect after login)
FRONTEND_URL=http://localhost:5173
